# Copy this file to .env.development.local (gitignored) and fill real values.
# This file is for development only.

# ------------------------------------------------------------
# Basic security
# ------------------------------------------------------------
WALINE_JWT_TOKEN=replace-with-openssl-rand-hex-32
AERISUN_SENTRY_DSN=
VITE_SENTRY_DSN=

# ------------------------------------------------------------
# Site OAuth (used by dev seed and runtime)
# ------------------------------------------------------------
AERISUN_OAUTH_GOOGLE_CLIENT_ID=
AERISUN_OAUTH_GOOGLE_CLIENT_SECRET=
AERISUN_OAUTH_GITHUB_CLIENT_ID=
AERISUN_OAUTH_GITHUB_CLIENT_SECRET=

# ------------------------------------------------------------
# SMTP / newsletter (used by dev seed)
# ------------------------------------------------------------
AERISUN_DEV_SEED_SUBSCRIPTION_ENABLED=false
AERISUN_SUBSCRIPTION_SMTP_AUTH_MODE=password
AERISUN_SUBSCRIPTION_SMTP_HOST=
AERISUN_SUBSCRIPTION_SMTP_PORT=587
AERISUN_SUBSCRIPTION_SMTP_USERNAME=
AERISUN_SUBSCRIPTION_SMTP_PASSWORD=
AERISUN_SUBSCRIPTION_SMTP_FROM_EMAIL=
AERISUN_SUBSCRIPTION_SMTP_FROM_NAME=
AERISUN_SUBSCRIPTION_SMTP_REPLY_TO=
AERISUN_SUBSCRIPTION_SMTP_USE_TLS=true
AERISUN_SUBSCRIPTION_SMTP_USE_SSL=false

# For Microsoft OAuth2 SMTP mode
AERISUN_SUBSCRIPTION_SMTP_OAUTH_TENANT=common
AERISUN_SUBSCRIPTION_SMTP_OAUTH_CLIENT_ID=
AERISUN_SUBSCRIPTION_SMTP_OAUTH_CLIENT_SECRET=
AERISUN_SUBSCRIPTION_SMTP_OAUTH_REFRESH_TOKEN=

# ------------------------------------------------------------
# AI model config (used by dev seed)
# ------------------------------------------------------------
AERISUN_DEV_SEED_AGENT_MODEL_ENABLED=false
AERISUN_DEV_SEED_AGENT_MODEL_PROVIDER=openai_compatible
AERISUN_DEV_SEED_AGENT_MODEL_BASE_URL=
AERISUN_DEV_SEED_AGENT_MODEL=
AERISUN_DEV_SEED_AGENT_MODEL_API_KEY=
AERISUN_DEV_SEED_AGENT_MODEL_TEMPERATURE=0.2
AERISUN_DEV_SEED_AGENT_MODEL_TIMEOUT_SECONDS=20
AERISUN_DEV_SEED_AGENT_MODEL_ADVISORY_PROMPT=

# ------------------------------------------------------------
# Webhook subscription (used by dev seed)
# ------------------------------------------------------------
AERISUN_DEV_SEED_WEBHOOK_NAME=dev-webhook
AERISUN_DEV_SEED_WEBHOOK_TARGET_URL=
AERISUN_DEV_SEED_WEBHOOK_SECRET=
AERISUN_DEV_SEED_WEBHOOK_EVENT_TYPES=webhook.test
AERISUN_DEV_SEED_WEBHOOK_HEADERS_JSON={}
AERISUN_DEV_SEED_WEBHOOK_TIMEOUT_SECONDS=10
AERISUN_DEV_SEED_WEBHOOK_MAX_ATTEMPTS=6
AERISUN_DEV_SEED_WEBHOOK_STATUS=active

# ------------------------------------------------------------
# OSS / object storage
# ------------------------------------------------------------
# OSS integration is not wired in backend yet.
# Keep your local OSS secrets here if you need them for external scripts.
# AERISUN_OSS_ENDPOINT=
# AERISUN_OSS_BUCKET=
# AERISUN_OSS_ACCESS_KEY_ID=
# AERISUN_OSS_ACCESS_KEY_SECRET=
