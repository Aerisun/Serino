# 复制为 .env.development.local 并填入真实值（此文件被 gitignore）
# cp .env.development.local.example .env.development.local
#
# setup-ports.sh 会自动在此文件末尾追加端口配置区块。

# ── 安全（建议填写） ──
WALINE_JWT_TOKEN=replace-with-openssl-rand-hex-32
AERISUN_SENTRY_DSN=
VITE_SENTRY_DSN=

# ── Site OAuth ──
AERISUN_OAUTH_GOOGLE_CLIENT_ID=
AERISUN_OAUTH_GOOGLE_CLIENT_SECRET=
AERISUN_OAUTH_GITHUB_CLIENT_ID=
AERISUN_OAUTH_GITHUB_CLIENT_SECRET=

# ── 更多可选配置 ──
# SMTP、AI model、Webhook 等开发种子配置项见 backend/src/aerisun/core/settings.py
# 中的 Settings 类（以 AERISUN_ 为前缀的环境变量均可在此覆盖）。
