# Published Docker Hub images
AERISUN_API_IMAGE=docker.io/aerisun/serino-api
AERISUN_WEB_IMAGE=docker.io/aerisun/serino-web
AERISUN_WALINE_IMAGE=docker.io/aerisun/serino-waline
AERISUN_IMAGE_TAG=latest

# App identity
AERISUN_APP_NAME=Aerisun
AERISUN_ENVIRONMENT=production

# Public URLs
AERISUN_DOMAIN=example.com
AERISUN_SITE_URL=https://example.com
AERISUN_WALINE_SERVER_URL=https://example.com/waline
AERISUN_CORS_ORIGINS=["https://example.com"]
WALINE_SECURE_DOMAINS=example.com

# Network
AERISUN_HOST=0.0.0.0
AERISUN_PORT=8000
WALINE_PORT=8360
AERISUN_HTTP_PORT=80
AERISUN_HTTPS_PORT=443

# Host storage mount
AERISUN_STORE_BIND_DIR=./.aerisun-store

# Shared storage inside containers
AERISUN_STORE_DIR=/srv/aerisun/store
AERISUN_DATA_DIR=/srv/aerisun/store
AERISUN_DB_PATH=/srv/aerisun/store/aerisun.db
AERISUN_WALINE_DB_PATH=/srv/aerisun/store/waline.db
AERISUN_MEDIA_DIR=/srv/aerisun/store/media
AERISUN_SECRETS_DIR=/srv/aerisun/store/secrets

# Runtime paths
AERISUN_API_BASE_PATH=/api
AERISUN_ADMIN_BASE_PATH=/admin/
AERISUN_WALINE_BASE_PATH=/waline
AERISUN_HEALTHCHECK_PATH=/api/v1/site/healthz
AERISUN_FRONTEND_DIST_DIR=/srv/aerisun/frontend
AERISUN_ADMIN_DIST_DIR=/srv/aerisun/admin

# App behavior
AERISUN_SEED_REFERENCE_DATA=false
AERISUN_LOG_FORMAT=json
AERISUN_LOG_LEVEL=INFO

# Optional integrations
AERISUN_SENTRY_DSN=
VITE_SENTRY_DSN=
WALINE_AVATAR_PROXY=https://avatar.75cdn.workers.dev
WALINE_GRAVATAR_STR=https://seccdn.libravatar.org/avatar/{{mail|md5}}

# Secrets: replace before first boot
WALINE_JWT_TOKEN=replace-with-openssl-rand-hex-32
