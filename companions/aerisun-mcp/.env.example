# Aerisun MCP companion configuration
# Copy to .env locally and fill in the API key before handing this package to an AI client.

AERISUN_MCP_BASE_URL="http://localhost:8080"
AERISUN_MCP_ENDPOINT="http://localhost:8080/api/mcp"
AERISUN_MCP_USAGE_URL="http://localhost:8080/api/agent/usage"
AERISUN_MCP_META_URL="http://localhost:8080/api/mcp-meta"
AERISUN_MCP_API_KEY=""

# Security defaults:
# - readonly mode stays on until a human deliberately turns it off
# - writes still require explicit allowlists even when readonly mode is off
AERISUN_MCP_REQUIRE_READONLY="true"
AERISUN_MCP_CONFIRM_BEFORE_WRITE="true"
AERISUN_MCP_ALLOWED_WRITE_TOOLS=""
AERISUN_MCP_ALLOWED_WRITE_RESOURCES=""
