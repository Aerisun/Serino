# 复制为 .env.production.local 并填入真实值（此文件被 gitignore）
# Secrets now live in ${AERISUN_SECRETS_DIR:-/srv/aerisun/store/secrets}:
# - waline_jwt_token.txt
# - waline.env（可由 waline_jwt_token.txt 派生生成，供 Waline Docker 容器使用）
# - sentry_dsn.txt
# - oauth_google_client_id.txt / oauth_google_client_secret.txt
# - oauth_github_client_id.txt / oauth_github_client_secret.txt
AERISUN_DOMAIN=yourdomain.com
AERISUN_SITE_URL=https://yourdomain.com
AERISUN_WALINE_SERVER_URL=https://yourdomain.com/waline
AERISUN_CORS_ORIGINS=["https://yourdomain.com"]
WALINE_SECURE_DOMAINS=yourdomain.com
AERISUN_BACKUP_SSH_KEY=
