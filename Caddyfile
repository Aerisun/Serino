{$AERISUN_DOMAIN:localhost} {
    encode zstd gzip

    # API 后端
    handle {$AERISUN_API_BASE_PATH:/api}/* {
        reverse_proxy api:{$AERISUN_PORT:8000}
    }

    # 资源文件
    handle /media/* {
        reverse_proxy api:{$AERISUN_PORT:8000}
    }

    handle /manifest.webmanifest {
        reverse_proxy api:{$AERISUN_PORT:8000}
    }

    handle /bootstrap.js {
        reverse_proxy api:{$AERISUN_PORT:8000}
    }

    # Waline 评论服务
    handle {$AERISUN_WALINE_BASE_PATH:/waline}* {
        uri strip_prefix {$AERISUN_WALINE_BASE_PATH:/waline}
        reverse_proxy waline:8360
    }

    # SEO / Feed XML
    handle /sitemap.xml {
        reverse_proxy api:{$AERISUN_PORT:8000}
    }

    handle /feed.xml {
        reverse_proxy api:{$AERISUN_PORT:8000}
    }

    handle /rss.xml {
        reverse_proxy api:{$AERISUN_PORT:8000}
    }

    handle /feeds.xml {
        reverse_proxy api:{$AERISUN_PORT:8000}
    }

    handle /feeds/* {
        reverse_proxy api:{$AERISUN_PORT:8000}
    }

    # 管理端 SPA
    handle_path {$AERISUN_ADMIN_BASE_PATH:/admin/}* {
        root * {$AERISUN_ADMIN_DIST_DIR:/srv/aerisun/admin}

        @hashed path /assets/*
        header @hashed Cache-Control "public, max-age=31536000, immutable"

        @unhashed {
            not path /assets/*
        }
        header @unhashed Cache-Control "no-cache, max-age=0, must-revalidate"

        try_files {path} /index.html
        file_server
    }

    # 前端 SPA
    handle {
        root * {$AERISUN_FRONTEND_DIST_DIR:/srv/aerisun/frontend}

        @hashed path /assets/*
        header @hashed Cache-Control "public, max-age=31536000, immutable"

        @unhashed {
            not path /assets/*
        }
        header @unhashed Cache-Control "no-cache, max-age=0, must-revalidate"

        try_files {path} /index.html
        file_server
    }
}
