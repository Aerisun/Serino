AERISUN_APP_NAME=Aerisun API
AERISUN_ENVIRONMENT=development
AERISUN_HOST=127.0.0.1
AERISUN_PORT=8000
AERISUN_DATA_DIR=.data
AERISUN_MEDIA_DIR=.media
AERISUN_SECRETS_DIR=.secrets
AERISUN_DB_PATH=.data/aerisun.db
AERISUN_LITESTREAM_CONFIG_PATH=./litestream.yml
AERISUN_LITESTREAM_REPLICA_URL=sftp://backup-user@backup-host:22/backup/aerisun/aerisun.db
AERISUN_BACKUP_RSYNC_URI=backup-user@backup-host:/backup/aerisun
AERISUN_BACKUP_SSH_PORT=22
AERISUN_SQLITE_BUSY_TIMEOUT_MS=5000
AERISUN_SEED_REFERENCE_DATA=true
