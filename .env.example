AERISUN_HOST=0.0.0.0
AERISUN_PORT=8000
AERISUN_STORE_DIR=/srv/aerisun/store
AERISUN_DATA_DIR=/srv/aerisun/store
AERISUN_DB_PATH=/srv/aerisun/store/aerisun.db
AERISUN_WALINE_DB_PATH=/srv/aerisun/store/waline.db
AERISUN_MEDIA_DIR=/srv/aerisun/store/media
AERISUN_SECRETS_DIR=/srv/aerisun/store/secrets
AERISUN_SITE_URL=http://localhost:5173
AERISUN_WALINE_SERVER_URL=http://localhost:8360
AERISUN_LITESTREAM_REPLICA_URL=sftp://backup-user@backup-host:22/backup/aerisun/aerisun.db
AERISUN_WALINE_LITESTREAM_REPLICA_URL=sftp://backup-user@backup-host:22/backup/aerisun/waline.db
AERISUN_BACKUP_RSYNC_URI=backup-user@backup-host:/backup/aerisun
AERISUN_BACKUP_SSH_PORT=22
AERISUN_BACKUP_SSH_KEY=
AERISUN_FRONTEND_UPSTREAM=host.docker.internal:8080
AERISUN_ADMIN_UPSTREAM=host.docker.internal:3001

# CORS: In production, set to your actual domain(s), JSON list format
# AERISUN_CORS_ORIGINS=["https://yourdomain.com","https://admin.yourdomain.com"]
# Production environment: set to "production" to enforce security checks
# AERISUN_ENVIRONMENT=production

# IMPORTANT: Change this to a strong random value before deploying!
WALINE_JWT_TOKEN=change-me
WALINE_SECURE_DOMAINS=localhost,127.0.0.1
WALINE_AVATAR_PROXY=https://avatar.75cdn.workers.dev
WALINE_GRAVATAR_STR=https://seccdn.libravatar.org/avatar/{{mail|md5}}
