{
  "name": "@serino/api-client",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "src/index.ts",
  "types": "src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./admin": "./src/generated/admin/admin.ts",
    "./site": "./src/generated/site/site.ts",
    "./site-auth": "./src/generated/site-auth/site-auth.ts",
    "./site-interactions": "./src/generated/site-interactions/site-interactions.ts",
    "./seo": "./src/generated/seo/seo.ts",
    "./models": "./src/generated/model/index.ts",
    "./schemas": "./src/generated/schemas.zod.ts"
  },
  "scripts": {
    "generate:api": "orval && node ./scripts/rebuild-model-index.mjs",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.typecheck.json --noEmit"
  },
  "dependencies": {
    "axios": "^1.7.9",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "orval": "^8.6.2",
    "vitest": "^3.2.1"
  },
  "peerDependencies": {
    "@tanstack/react-query": "^5.0.0"
  },
  "peerDependenciesMeta": {
    "@tanstack/react-query": {
      "optional": true
    }
  }
}
