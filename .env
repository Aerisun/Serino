# ── Aerisun 共享基础配置（tracked，跨环境通用） ──

AERISUN_APP_NAME="Aerisun API"
AERISUN_SQLITE_BUSY_TIMEOUT_MS=5000
AERISUN_SESSION_TTL_HOURS=24
AERISUN_LOG_LEVEL=INFO

# 路径契约（tracked，跨前后端 / compose / Caddy 共享）
AERISUN_API_BASE_PATH=/api
AERISUN_ADMIN_BASE_PATH=/admin/
AERISUN_WALINE_BASE_PATH=/waline
AERISUN_HEALTHCHECK_PATH=/api/v1/public/healthz
AERISUN_FRONTEND_DIST_DIR=/srv/aerisun/frontend
AERISUN_ADMIN_DIST_DIR=/srv/aerisun/admin

# Feed 抓取
AERISUN_FEED_CRAWL_ENABLED=true
AERISUN_FEED_CRAWL_INTERVAL_HOURS=6
AERISUN_FEED_CRAWL_TIMEOUT_CONNECT=10
AERISUN_FEED_CRAWL_TIMEOUT_READ=15
AERISUN_FEED_CRAWL_MAX_ITEMS_PER_SOURCE=20

# Waline（非密钥）
WALINE_AVATAR_PROXY=https://avatar.75cdn.workers.dev
WALINE_GRAVATAR_STR='https://seccdn.libravatar.org/avatar/{{mail|md5}}'

# 备份（生产环境在 .env.production.local 覆盖真实值）
AERISUN_LITESTREAM_REPLICA_URL=sftp://backup-user@backup-host:22/backup/aerisun/aerisun.db
AERISUN_WALINE_LITESTREAM_REPLICA_URL=sftp://backup-user@backup-host:22/backup/aerisun/waline.db
AERISUN_BACKUP_RSYNC_URI=backup-user@backup-host:/backup/aerisun
AERISUN_BACKUP_SSH_PORT=22
