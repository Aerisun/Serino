# 这是生产环境配置示例文件。安装器会生成并维护 /etc/serino/serino.env，
# 正常情况下不需要手动创建或编辑本文件。
#
# 仅在以下场景需要参考或手动维护：
# 1. 你不走安装器，而是自己按新模型部署到 /opt/serino + /etc/serino/serino.env。
# 2. 服务安装完成后，需要审阅或微调生产配置。
#
# 新模型约定：
# - 程序与 compose 载荷：/opt/serino
# - 生产配置：/etc/serino/serino.env
# - 运行数据：/var/lib/serino
# - 后续运维：sercli status|logs|restart|upgrade|doctor|uninstall
#
# 首装注意：
# - 必须先设置 AERISUN_BOOTSTRAP_ADMIN_USERNAME 和 AERISUN_BOOTSTRAP_ADMIN_PASSWORD。
# - 这组凭据只用于首次空库启动时初始化网站管理台管理员。
# - 首装成功并确认后台可登录后，应立即从 /etc/serino/serino.env 删除这两项。

# ── 必填：站点身份 ──
AERISUN_DOMAIN=yourdomain.com
AERISUN_SITE_URL=https://yourdomain.com
AERISUN_WALINE_SERVER_URL=https://yourdomain.com/waline
AERISUN_CORS_ORIGINS='["https://yourdomain.com"]'
WALINE_SECURE_DOMAINS=yourdomain.com

# ── 必填：密钥 ──
WALINE_JWT_TOKEN=

# ── 生产初始化 ──
# 生产首装会灌入 bootstrap scaffold，升级时会自动执行已注册的数据回填。
# 首装还必须提供后台管理员用户名和密码；首装成功并确认可登录后，应立即从本文件删除这两项。
AERISUN_SEED_REFERENCE_DATA=true
AERISUN_DATA_BACKFILL_ENABLED=true
AERISUN_BOOTSTRAP_ADMIN_USERNAME=
AERISUN_BOOTSTRAP_ADMIN_PASSWORD=

# ── 可选：监控 ──
AERISUN_SENTRY_DSN=
VITE_SENTRY_DSN=

# ── 发布镜像（docker-compose.release.yml / installer 专用） ──
# 生产环境默认从阿里云公开仓库拉取镜像；如果通过安装器部署，安装器会自动写入实际使用的镜像源。
AERISUN_IMAGE_REGISTRY=crpi-hwvtw8db2uk7bil0.cn-beijing.personal.cr.aliyuncs.com/serino
AERISUN_IMAGE_TAG=latest

# ── 可选：网络端口（默认值通常不需要改） ──
# AERISUN_HTTP_PORT=80
# AERISUN_HTTPS_PORT=443
# AERISUN_PORT=8000
# WALINE_PORT=8360

# ── 可选：宿主机存储挂载点 ──
# AERISUN_STORE_BIND_DIR=/var/lib/serino
