#!/usr/bin/env bash
set -euo pipefail

SELF_PATH="$(readlink -f "${BASH_SOURCE[0]}")"
SCRIPT_DIR="$(cd "$(dirname "${SELF_PATH}")" && pwd)"
INSTALLER_ROOT="$(cd "${SCRIPT_DIR}/.." && pwd)"

if [[ "${1:-}" != "--as-root" ]] && [[ "$(id -u)" -ne 0 ]]; then
  if command -v sudo >/dev/null 2>&1; then
    exec sudo "$0" --as-root "$@"
  fi
  echo "需要 root 或 sudo 才能执行 sercli。" >&2
  exit 1
fi

if [[ "${1:-}" == "--as-root" ]]; then
  shift
fi

# shellcheck disable=SC1091
source "${INSTALLER_ROOT}/lib/common.sh"
# shellcheck disable=SC1091
source "${INSTALLER_ROOT}/lib/env.sh"
# shellcheck disable=SC1091
source "${INSTALLER_ROOT}/lib/docker.sh"

usage() {
  cat <<'EOF'
用法：
  sercli status
  sercli logs [service...]
  sercli restart
  sercli upgrade [vX.Y.Z]
  sercli uninstall [--force]
  sercli doctor [--json]
EOF
}

cmd_status() {
  ensure_supported_existing_installation
  compose ps
  echo
  run_as_root systemctl --no-pager --full status "${SERINO_SYSTEMD_UNIT}" || true
  echo
  load_env_file "${AERISUN_ENV_FILE}"
  echo "站点地址：${AERISUN_SITE_URL:-<未配置>}"
  echo "当前镜像源：${AERISUN_IMAGE_REGISTRY:-<未配置>}"
  echo "当前镜像标签：${AERISUN_IMAGE_TAG:-<未配置>}"
  if curl --fail --silent --show-error "http://127.0.0.1:${AERISUN_PORT:-8000}${AERISUN_HEALTHCHECK_PATH:-/api/v1/site/healthz}" >/dev/null 2>&1; then
    echo "健康检查：ok"
  else
    echo "健康检查：fail"
    return 1
  fi
}

cmd_logs() {
  ensure_supported_existing_installation
  if [[ "$#" -gt 0 ]]; then
    compose logs --tail 120 "$@"
    return 0
  fi
  compose logs --tail 120 api waline caddy
}

cmd_restart() {
  ensure_supported_existing_installation
  restart_serino_service
  wait_for_release_ready
}

cmd_upgrade() {
  exec "${INSTALLER_ROOT}/upgrade.sh" "$@"
}

cmd_uninstall() {
  exec "${INSTALLER_ROOT}/uninstall.sh" "$@"
}

cmd_doctor() {
  exec bash "${INSTALLER_ROOT}/doctor.sh" "$@"
}

main() {
  local command="${1:-}"
  shift || true

  case "${command}" in
    status)
      cmd_status "$@"
      ;;
    logs)
      cmd_logs "$@"
      ;;
    restart)
      cmd_restart "$@"
      ;;
    upgrade)
      cmd_upgrade "$@"
      ;;
    uninstall)
      cmd_uninstall "$@"
      ;;
    doctor)
      cmd_doctor "$@"
      ;;
    *)
      usage
      exit 1
      ;;
  esac
}

main "$@"
